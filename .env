# .env is better suited for public variables, ie, variables that should not commited
# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"

# Clerk Configuration
# Get your publishable key from https://clerk.com/
VITE_CLERK_PUBLISHABLE_KEY=__CLERK_PUBLISHABLE_KEY__

# Supabase Configuration
# Get your project URL and anon key from https://supabase.com/dashboard
VITE_SUPABASE_URL=https://eefcgqhcyujenrbmzsxj.supabase.co
VITE_SUPABASE_ANON_KEY=__SUPABASE_ANON_KEY__
